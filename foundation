.role-card.admin      .role-icon-wrap { background: #fce4ec; border-color: #f48fb1; }

/* ── ANNOTATIONS ────────────────────────────────────────── */
.annotation {
  font-family: var(--ff-mono);
  font-size: 9.5px;
  color: var(--accent);
  background: var(--accent-2);
